# Normalize line endings to LF on commit, checkout as OS-native
* text=auto

# Source code
*.v    text
*.sv   text
*.xdc  text
*.c    text
*.h    text
*.py   text
*.md   text
*.txt  text
*.coe  text
*.ld   text

# Vivado / SDK project files
*.xpr  text
*.bd   text
*.bda  text
*.xci  text
*.prj  text
*.spec text

# Binary files — do not normalize
*.pdf  binary
*.xsa  binary
*.bin  binary
*.ipynb text
